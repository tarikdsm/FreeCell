{
  "name": "@freecell/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm wasm:build",
    "dev": "vite",
    "prebuild": "pnpm wasm:build",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "lint": "biome check src/audio.ts src/game.ts src/main.ts src/style.css index.html vite.config.ts",
    "format": "biome format --write src/audio.ts src/game.ts src/main.ts src/style.css index.html vite.config.ts",
    "wasm:build": "node ../../tools/scripts/run-wasm-pack.mjs build ../../crates/freecell_wasm --target web --out-dir ../../apps/web/src/wasm/freecell_wasm --out-name freecell_wasm"
  },
  "dependencies": {
    "pixi.js": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
